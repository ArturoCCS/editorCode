<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@styles.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controlador.MainController">
    <top>
        <HBox spacing="0" styleClass="top-bar">
            <children>
                <Button fx:id="btnNew" text="Nuevo" />
                <Button fx:id="btnOpen" text="Abrir" />
                <Button fx:id="btnToggleTokens" text="Extras" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
            <padding><Insets bottom="2" left="10" right="10" top="2" /></padding>
        </HBox>
    </top>
    <center>
        <SplitPane fx:id="mainSplit" dividerPositions="0.5">
            <items>
                <AnchorPane>
                    <children>
                        <TabPane fx:id="tabPane" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />
                    </children>
                </AnchorPane>
                <VBox fx:id="tokenBox" spacing="10" styleClass="token-sidebar">
                    <padding><Insets bottom="12" left="8" right="8" top="12" /></padding>
                </VBox>
            </items>
        </SplitPane>
    </center>
</BorderPane>
